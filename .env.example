# Copy to .env and fill in real values. .env is not committed.
JENKINS_ADMIN_USER=admin
JENKINS_ADMIN_PASSWORD=change-me

# Left empty on first run. scripts/jenkins-bootstrap.sh fills this in once the
# controller is up, so the agent can connect.
JENKINS_AGENT_SECRET=

# GHCR personal access token, scope "write:packages". Used to create a Jenkins
# credential for pushing images (see scripts/jenkins-ghcr-credential.sh).
GHCR_USERNAME=
GHCR_PAT=

# Grafana local login (monitoring stack).
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
