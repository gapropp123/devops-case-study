{
  "title": "demo-app",
  "uid": "demo-app",
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"demo-app\"}[1m])) by (uri)",
          "legendFormat": "{{uri}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "p95 latency (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"demo-app\"}[5m])) by (le, uri))",
          "legendFormat": "{{uri}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "5xx error rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"demo-app\", status=~\"5..\"}[1m]))",
          "legendFormat": "5xx/s"
        }
      ]
    },
    {
      "id": 4,
      "title": "JVM heap used (bytes)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{job=\"demo-app\", area=\"heap\"}",
          "legendFormat": "{{id}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Process CPU usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "process_cpu_usage{job=\"demo-app\"}",
          "legendFormat": "cpu"
        }
      ]
    },
    {
      "id": 6,
      "title": "Up",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        { "expr": "up{job=\"demo-app\"}", "legendFormat": "up" }
      ]
    }
  ]
}
